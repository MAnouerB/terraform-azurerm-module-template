# Local .terraform directories
**/.terraform/*
**/.terraform.lock.hcl.backup

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (may contain sensitive data)
*.tfvars
*.tfvars.json
!examples/**/*.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan
*.tfplan.*

# Terraform CLI logs
terraform.log

# ---- Go / Terratest ----
test/vendor/
test/*.test
test/coverage.out
test/coverage.html
*.exe
*.exe~
*.dll
*.so
*.dylib

# ---- Azure credentials ----
*.pem
*.pfx
*.publishsettings
.azure/
azure.env
.env
.env.*
!.env.example

# ---- Editors / IDE ----
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Infracost ----
infracost.json
infracost-base.json
.infracost/

# ---- tfsec / checkov reports ----
tfsec-report.*
checkov-report.*
results.sarif

# ---- terraform-docs cache ----
.terraform-docs.cache

# ---- Claude Code local ----
.claude/settings.local.json